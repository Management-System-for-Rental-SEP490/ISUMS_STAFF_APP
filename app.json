{
  "expo": {
    "name": "ISUMS Staff",
    "slug": "isums-staff-app",
    "scheme": "isumsstaff",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logob.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logob.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "androidStatusBar": {
      "translucent": true,
      "backgroundColor": "#37b584"
    },
    "androidNavigationBar": {
      "backgroundColor": "#00000000",
      "barStyle": "light-content"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/logob.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.NFC",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_WIFI_STATE",
        "android.permission.NEARBY_WIFI_DEVICES",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "isumsstaff"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "package": "com.anonymous.isumsstaffapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-navigation-bar",
        {
          "position": "absolute",
          "backgroundColor": "#00000000",
          "barStyle": "light"
        }
      ],
      "expo-web-browser",
      [
        "expo-media-library",
        {
          "photosPermission": "Ứng dụng cần truy cập ảnh để bạn chọn ảnh từ thư viện.",
          "savePhotosPermission": "Ứng dụng cần lưu ảnh bạn chụp vào thư viện ảnh trên máy.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ]
  }
}
